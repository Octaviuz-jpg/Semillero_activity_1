{
  "name": "High Priority - Slack Alert",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "/webhooks/high-priority-alert",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "channel": "={{ $json.slackChannel }}",
        "text": "={{ $json.message }}"
      },
      "name": "Slack",
      "type": "n8n-nodes-base.slack",
      "position": [450, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[ { "node": "Slack" } ]] }
  }
}
